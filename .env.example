# Autonomous Research Agent - Copy to .env and fill values
# Get free Groq API key: https://console.groq.com/keys

GROQ_API_KEY=your_groq_api_key_here

# Search settings
SEARCH_MAX_RESULTS=5
SEARCH_TIMEOUT=30

# LLM settings
LLM_MODEL=llama3-8b-8192  # or llama3-70b-8192, mixtral-8x7b-32768
LLM_TEMPERATURE=0.1

# Paths
DATA_DIR=./data
KNOWLEDGE_DB_PATH=./data/knowledge_db
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Streamlit
STREAMLIT_PORT=8501

